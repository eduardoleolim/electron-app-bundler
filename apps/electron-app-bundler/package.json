{
  "name": "electron-app-bundler",
  "version": "6.0.1",
  "description": "Use esbuild with electron",
  "type": "module",
  "main": "dist/app/index.mjs",
  "scripts": {
    "clean:package": "clean-pkg-json",
    "build": "rimraf dist && tsc",
    "test": "jest",
    "changelog": "conventional-changelog -i CHANGELOG.md -s -r 0"
  },
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "electron-app-bundler": "dist/app/index.mjs"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eduardoleolim/electron-app-bundler.git"
  },
  "keywords": [
    "esbuild",
    "vite",
    "electron",
    "hot reload",
    "hmr",
    "renderer",
    "cli",
    "build-tool",
    "astro"
  ],
  "author": "eduardoleolim",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/eduardoleolim/electron-app-bundler/issues"
  },
  "homepage": "https://github.com/eduardoleolim/electron-app-bundler#readme",
  "dependencies": {
    "chalk": "catalog:",
    "chokidar": "catalog:",
    "commander": "catalog:",
    "compression": "catalog:",
    "connect": "catalog:",
    "debounce": "catalog:",
    "dependency-tree": "catalog:",
    "http-proxy": "catalog:",
    "js-yaml": "catalog:",
    "livereload": "catalog:"
  },
  "devDependencies": {
    "@types/compression": "catalog:",
    "@types/connect": "catalog:",
    "@types/debounce": "catalog:",
    "@types/http-proxy": "catalog:",
    "@types/jest": "catalog:",
    "@types/js-yaml": "catalog:",
    "@types/livereload": "catalog:",
    "@types/node": "catalog:",
    "@typescript-eslint/eslint-plugin": "catalog:",
    "@typescript-eslint/parser": "catalog:",
    "astro": "catalog:",
    "clean-pkg-json": "catalog:",
    "conventional-changelog": "catalog:",
    "esbuild": "catalog:",
    "eslint": "catalog:",
    "eslint-config-prettier": "catalog:",
    "eslint-plugin-prettier": "catalog:",
    "jest": "catalog:",
    "jest-ctrf-json-reporter": "catalog:",
    "lint-staged": "catalog:",
    "prettier": "catalog:",
    "rimraf": "catalog:",
    "ts-jest": "catalog:",
    "ts-node": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "vite": "catalog:"
  },
  "peerDependencies": {
    "astro": "catalog:",
    "esbuild": "catalog:",
    "vite": "catalog:"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    },
    "astro": {
      "optional": true
    }
  },
  "lint-staged": {
    "*.{js,ts,mjs,mts}": [
      "eslint --fix"
    ]
  }
}
