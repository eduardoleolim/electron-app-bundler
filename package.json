{
  "packageManager": "pnpm@11.1.3",
  "scripts": {
    "bundler:audit": "pnpm --filter electron-app-bundler audit --prod",
    "bundler:test": "pnpm --filter electron-app-bundler test",
    "bundler:build": "pnpm --filter electron-app-bundler build",
    "lint": "eslint --quiet --fix",
    "prepare": "husky",
    "basic-js:dev": "pnpm --filter basic-js dev",
    "basic-js:build": "pnpm --filter basic-js build",
    "basic-ts:dev": "pnpm --filter basic-ts dev",
    "basic-ts:build": "pnpm --filter basic-ts build",
    "svelte-ts:dev": "pnpm --filter svelte-ts dev",
    "svelte-ts:build": "pnpm --filter svelte-ts build",
    "react-ts:dev": "pnpm --filter react-ts dev",
    "react-ts:build": "pnpm --filter react-ts build",
    "tailwind-ts:dev": "pnpm --filter tailwind-ts dev",
    "tailwind-ts:build": "pnpm --filter tailwind-ts build",
    "vite-ts:dev": "pnpm --filter vite-ts dev",
    "vite-ts:build": "pnpm --filter vite-ts build",
    "astro:dev": "pnpm --filter astro dev",
    "astro:build": "pnpm --filter astro build",
    "changelog": "conventional-changelog -i CHANGELOG.md -s -r 0"
  },
  "engines": {
    "node": ">=22.19.0",
    "pnpm": ">=11.0.0"
  },
  "keywords": [
    "esbuild",
    "vite",
    "electron",
    "hot reload",
    "hmr",
    "renderer",
    "cli",
    "build-tool",
    "astro"
  ],
  "author": "eduardoleolim",
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "catalog:",
    "@eslint/js": "catalog:",
    "@typescript-eslint/eslint-plugin": "catalog:",
    "@typescript-eslint/parser": "catalog:",
    "conventional-changelog": "catalog:",
    "eslint": "catalog:",
    "eslint-config-prettier": "catalog:",
    "eslint-plugin-prettier": "catalog:",
    "globals": "catalog:",
    "husky": "catalog:",
    "lint-staged": "catalog:",
    "prettier": "catalog:",
    "typescript-eslint": "catalog:"
  },
  "lint-staged": {
    "*.{js,ts,mjs,mts}": [
      "eslint --fix"
    ]
  }
}
